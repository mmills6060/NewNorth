# MySQL (local: docker compose up -d)
DATABASE_URL=mysql://newnorth:newnorth@localhost:3306/newnorth

# Optional: extra seed URLs for discovery (comma-separated)
CRAWL_SEED_URLS=

# Automatic board search (DuckDuckGo). Set to false to disable.
CRAWL_SEARCH_ENABLED=true
# Optional custom search queries (comma-separated)
CRAWL_SEARCH_QUERIES=

# Probe known company slugs against the Greenhouse API (most reliable discovery).
CRAWL_PROBE_ENABLED=true
CRAWL_PROBE_MAX_CANDIDATES=400
# Optional extra slugs to probe (comma-separated)
CRAWL_PROBE_SLUGS=

# Protect crawl endpoint in production (send as x-crawl-secret header or ?secret=)
CRAWL_SECRET=

# Optional crawl limits
CRAWL_MAX_PAGES=100
CRAWL_MAX_BOARDS=500
CRAWL_CONCURRENCY=5
CRAWL_FETCH_TIMEOUT_MS=15000
CRAWL_REQUEST_DELAY_MS=300
CRAWL_MAX_JOBS_DISPLAYED=500
